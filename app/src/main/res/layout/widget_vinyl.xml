<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Circle Vinyl Container -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp">

        <!-- Circular Vinyl Art -->
        <ImageView
            android:id="@+id/widget_vinyl_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/default_album_art" />

        <!-- Floating Play/Pause Button (Bottom Left) -->
        <ImageView
            android:id="@+id/widget_vinyl_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="4dp"
            android:background="@drawable/bg_circle_floating"
            android:padding="14dp"
            android:src="@drawable/ic_play" />

        <!-- Floating Like Button (Top Right) -->
        <ImageView
            android:id="@+id/widget_vinyl_like"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:background="@drawable/bg_circle_floating"
            android:padding="10dp"
            android:src="@drawable/ic_widget_heart_outline_nav" />
    </FrameLayout>

    <!-- Song Title -->
    <TextView
        android:id="@+id/widget_vinyl_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:singleLine="true"
        android:text="Song Title"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
