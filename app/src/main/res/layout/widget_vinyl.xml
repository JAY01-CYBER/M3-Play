<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp">

        <ImageView
            android:id="@+id/widget_vinyl_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@drawable/default_album_art" />

        <FrameLayout
            android:id="@+id/widget_vinyl_like_container"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_circle_floating">

            <ImageView
                android:id="@+id/widget_vinyl_like_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_heart_outline_nav" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/widget_vinyl_play_container"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_floating">

            <ImageView
                android:id="@+id/widget_vinyl_play_icon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play" />
        </FrameLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/widget_vinyl_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="Song Title"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
